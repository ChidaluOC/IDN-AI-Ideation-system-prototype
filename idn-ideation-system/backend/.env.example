# Anthropic API key for live AI mode.
# Leave blank (or omit this file) to run in mock/demo mode.
ANTHROPIC_API_KEY=

# Brave Search API key — enables the AI to search the web during chat.
# Get a free key (2000 queries/month) at https://brave.com/search/api/
# Leave blank to disable web search (AI will answer from its training data only).
BRAVE_SEARCH_API_KEY=
